# Trae Local API Configuration
# TRAE_EDITION 取值:
#   cn      - Trae CN 国内版(目录:Trae CN,tc 加密)
#   solo    - TRAE SOLO CN 独立部署版(目录:TRAE SOLO CN,tc 加密)
#   sg      - Trae 国际版(目录:Trae,明文 JSON)
#   solo-sg - TRAE SOLO 国际版(目录:TRAE SOLO,tc 加密)
# CN/SOLO 使用 https://trae-api-cn.mchost.guru 端点
# SG/SOLO-SG 使用 https://a0ai-api-sg.byteintlapi.com 端点
TRAE_EDITION=cn
API_KEY=your-custom-api-key
PORT=19900
WORKSPACE_DIR=./output
# Max context tokens for conversation history (default: 200000)
# Adjust based on Trae API model context window limits
# MAX_CONTEXT_TOKENS=200000
# If auto-decrypt fails, set token manually:
# TRAE_MANUAL_TOKEN=eyJ...
